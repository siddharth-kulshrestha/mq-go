      "index": "aI",
      "roundness": null,
      "seed": 1580431630,
      "version": 283,
      "versionNonce": 1707606286,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1758269311444,
      "link": null,
      "locked": false,
      "text": "Phase 1: \n- Store a topic in a store\n- Create publisher and Consumers\n- Interact with publisher and consumer via http / tcp \n- Create pull based consumers\n- Create a simple SDK\n\n- Add GRPC connection and create a client library.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Phase 1: \n- Store a topic in a store\n- Create publisher and Consumers\n- Interact with publisher and consumer via http / tcp \n- Create pull based consumers\n- Create a simple SDK\n\n- Add GRPC connection and create a client library.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
