      "boundElements": null,
      "updated": 1758269076441,
      "link": null,
      "locked": false,
      "text": "* Good to abstract storage out of topics so that they can be stored on any database -> For now we can use In memory store\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "* Good to abstract storage out of topics so that they can be stored on any database -> For now we can use In memory store\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "xOl64_tSAilVYz7lYfMVN",
      "type": "text",
      "x": 296.8333261476627,
      "y": 690.4999997019769,
      "width": 531.0394897460938,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
